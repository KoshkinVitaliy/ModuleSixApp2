<Window x:Class="ModuleSixApp2.View.ValidationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ModuleSixApp2.View"
        mc:Ignorable="d"
        Title="Валидация данных" 
        MinHeight="450" 
        MinWidth="800"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center">
            <Button Content="Получить данные"
                    Width="300"
                    Height="40"
                    Margin="40"
                    Click="Get_Data_Button_Click"/>
            <Button Content="Отправить результат теста"
                    Width="300"
                    Height="40"
                    Margin="40"/>
        </StackPanel>
        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center">
            <TextBlock x:Name="DataTextBlock"
                       Width="300"
                       Height="40"
                       Margin="40"/>
            <TextBlock x:Name="ResultTextBlock"
                       Width="300"
                       Height="40"
                       Margin="40"/>
        </StackPanel>
    </Grid>
</Window>
